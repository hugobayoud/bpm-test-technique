{
  "expo": {
    "name": "bpm-test-technique",
    "slug": "bpm-test-technique",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bpm-test-technique",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0D0D",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.hugobayoud.bpmtesttechnique"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hugobayoud.bpmtesttechnique"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0D0D",
          "image": "./assets/images/android-icon-foreground.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd8e42bc-b34d-4175-901c-1f06d8fad53c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bd8e42bc-b34d-4175-901c-1f06d8fad53c"
    }
  }
}
