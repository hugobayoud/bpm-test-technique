{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  // supabase/: Deno runtime (Deno globals) — type-checked at deploy time by
  // the supabase CLI, not by tsc.
  "exclude": ["node_modules", "supabase"]
}
